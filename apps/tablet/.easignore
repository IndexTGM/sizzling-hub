# Git / Environment
.gitignore
.env.example
.env.*

# Meta
LICENSE
README.md

# Package lock (EAS resolves dependencies)
package-lock.json

# Dev scripts
patch-supabase.js

# Metro (dev bundler)
metro.config.js

# TypeScript config (not needed at runtime)
tsconfig.json

# Native build directory (generated by expo prebuild - not needed for EAS cloud builds)
/android/
android/

# CMake native build caches (huge - generated during local native builds)
node_modules/**/android/.cxx/
node_modules/**/android/build/
