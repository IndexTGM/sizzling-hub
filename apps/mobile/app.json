{
  "expo": {
    "name": "Sizzling Hub",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sizzlinghub",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "jsEngine": "jsc",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.bendevs.sizzlinghub"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "locationAlwaysAndWhenInUsePermission": "Allow Sizzling Hub to use your location to track deliveries.",
          "locationAlwaysPermission": "Allow Sizzling Hub to track your location in the background while delivering orders.",
          "locationWhenInUsePermission": "Allow Sizzling Hub to access your location while using the app."
        }
      ]
    ],
    "jsEngine": "jsc",
    "experiments": {
      "typedRoutes": true,
      "newArchEnabled": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3e71befc-3aec-40de-8e4b-5ad406d38e71"
      }
    }
  }
}
